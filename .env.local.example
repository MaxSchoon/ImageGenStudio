# Image Generation Studio - Environment Variables Example
# Copy this file to .env.local and fill in your actual API keys

# =============================================================================
# Site Access Password
# =============================================================================
# Set an 8-character password to protect access to the app
SITE_PASSWORD=changeme1

# =============================================================================
# OpenRouter and OpenAI API Setup
# =============================================================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_AGENT_MODEL=openai/gpt-5.5
OPENROUTER_CHAT_MODEL=openai/gpt-5.4-mini
OPENROUTER_PROMPT_MODEL=openai/gpt-5.4-mini
NEXT_PUBLIC_APP_URL=http://localhost:3000

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# =============================================================================
# Legacy direct-provider settings
# =============================================================================
# The current app routes image generation through OpenRouter. Keep these only if
# you still run older local branches that call providers directly.

# =============================================================================
# xAI Grok API Setup
# =============================================================================
# Get your API key from: https://console.x.ai or https://x.ai
# You can use either GROK_API_KEY or XAI_API_KEY (both are supported)
GROK_API_KEY=your_grok_api_key_here
# OR alternatively:
# XAI_API_KEY=your_grok_api_key_here

# Optional: Image generation model (default: grok-imagine-image)
GROK_MODEL=grok-imagine-image
# Optional: Text completion model (default: grok-2-1212)
GROK_COMPLETION_MODEL=grok-2-1212

# =============================================================================
# Hugging Face API Setup (FLUX.1-Kontext)
# =============================================================================
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here
# Optional: Image generation model (default: black-forest-labs/FLUX.1-Kontext-dev)
HF_MODEL=black-forest-labs/FLUX.1-Kontext-dev
# Optional: Provider for fast inference (default: fal-ai)
HF_PROVIDER=auto

# =============================================================================
# Hugging Face API Setup (Qwen)
# =============================================================================
# Uses the same HF_TOKEN as FLUX.1-Kontext
# Optional: Qwen image-to-image model (default: Qwen/Qwen-Image-Edit)
HF_MODEL2=Qwen/Qwen-Image-Edit
